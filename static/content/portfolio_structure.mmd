graph TD
    subgraph UI ["Client-Side UI Layer"]
        Browser["User Web Browser"]
        Templates["Dynamic View Templates"]
        Assets["Static UI Assets"]
    end

    subgraph Gateway ["API Gateway & Controller"]
        Router["Central Application Router"]
        Config["Environment Configuration"]
    end

    subgraph BusinessLogic ["Business Logic Layer"]
        CalcModule["Logic & Computation Module"]
        ContactModule["REST API & Contact Module"]
